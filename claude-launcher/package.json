{
  "name": "claude-launcher",
  "version": "1.0.0",
  "description": "Free Claude Code Launcher with embedded terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.fcc.launcher",
    "productName": "Claude Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "pty-bridge.js",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "pty-bridge.js",
      "node_modules/node-pty/**/*",
      "node_modules/xterm/**/*",
      "node_modules/xterm-addon-fit/**/*",
      "node_modules/xterm-addon-web-links/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Claude-Launcher.exe"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
